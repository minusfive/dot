adjust-cell-height = 4

auto-update-channel = tip

custom-shader = ~/.config/ghostty/shaders/cursor_synesthaxia(tweened).glsl

theme = Catppuccin Mocha
font-family = JetBrains Mono
font-size = 18
font-feature = -calt,-clig,-liga
font-thicken = false
font-thicken-strength = 50

cursor-style = block
cursor-style-blink = true
selection-foreground = #11111b
selection-background = #cba6f7

split-divider-color = #313244
unfocused-split-opacity = 0.7

window-padding-x = 0
window-padding-y = 0
window-decoration = auto

working-directory = ~/dev

shell-integration = detect
shell-integration-features = no-cursor

keybind = super+right=goto_split:right
keybind = super+left=goto_split:left
keybind = super+down=goto_split:down
keybind = super+up=goto_split:up

keybind = super+shift+right=new_split:right
keybind = super+shift+left=new_split:left
keybind = super+shift+down=new_split:down
keybind = super+shift+up=new_split:up

keybind = shift+right=resize_split:right,10
keybind = shift+left=resize_split:left,10
keybind = shift+down=resize_split:down,10
keybind = shift+up=resize_split:up,10

keybind = super+z=toggle_split_zoom
keybind = super+t=new_tab
keybind = super+shift+w=close_tab

keybind = shift+page_up=scroll_page_fractional:-0.5
keybind = shift+page_down=scroll_page_fractional:0.5
