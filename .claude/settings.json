{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Read(.agents/**)",
      "Read(~/.agents/**)",
      "Read(~/.claude/**)",
      "Glob(.agents/**)",
      "Glob(~/.agents/**)",
      "Glob(~/.claude/**)",
      "Grep(.agents/**)",
      "Grep(~/.agents/**)",
      "Grep(~/.claude/**)"
    ],
    "defaultMode": "plan"
  },
  "model": "sonnet[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "forceLoginMethod": "console",
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "additionalDirectories": ["./.agents", "~/.agents"]
}
